{
  "name": "express-security-lab",
  "version": "1.0.0",
  "description": "Laboratório educacional em Node.js e Express.js para demonstrar vulnerabilidades comuns em APIs REST e suas respectivas mitigações, com foco em OWASP Top 10, XSS, Directory Traversal, brute force, tratamento seguro de erros e hardening backend.",
  "main": "safeApp.js",
  "private": true,
  "scripts": {
    "start": "npm run start:safe",
    "start:vulnerable": "node vulnerableApp.js",
    "start:safe": "node safeApp.js",
    "dev:vulnerable": "node --watch vulnerableApp.js",
    "dev:safe": "node --watch safeApp.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "test": "node --test tests/safeApp.test.js",
    "test:vulnerable": "node --test tests/vulnerableApp.test.js",
    "test:vulnerable:silent": "NODE_ENV=production node --test tests/vulnerableApp.test.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "expressjs",
    "javascript",
    "api-security",
    "web-security",
    "owasp",
    "owasp-top-10",
    "xss",
    "directory-traversal",
    "brute-force",
    "secure-coding",
    "backend",
    "devsecops"
  ],
  "author": "Felipe Santos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Felps03/express-vulnerabilities-demo.git"
  },
  "bugs": {
    "url": "https://github.com/Felps03/express-vulnerabilities-demo/issues"
  },
  "homepage": "https://github.com/Felps03/express-vulnerabilities-demo#readme",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0"
  }
}